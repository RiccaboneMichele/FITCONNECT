  "curl_commands": {
    "description": "Comandi cURL pronti per testare gli endpoint",
    
    "trainer_registration": "curl -X POST http://localhost:8080/api/trainers/register -H 'Content-Type: application/json' -d '{\"user_id\": 5, \"bio\": \"Trainer professionista\", \"hourly_rate\": 35.0, \"location\": \"Milano\", \"experience_years\": 8, \"specialization_ids\": [1, 2]}'",
    
    "trainer_search_all": "curl 'http://localhost:8080/api/trainers/search'",
    
    "trainer_search_filtered": "curl 'http://localhost:8080/api/trainers/search?specialization=powerlifting&location=Milano&max_price=40'",
    
    "session_booking": "curl -X POST http://localhost:8080/api/sessions -H 'Content-Type: application/json' -d '{\"client_id\": 10, \"trainer_id\": 1, \"date\": \"2026-07-15\", \"time\": \"10:00\", \"notes\": \"Prima sessione\"}'"
  },

