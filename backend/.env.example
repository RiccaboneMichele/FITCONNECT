# FitConnect - Environment Variables
# Copia questo file in .env e modifica i valori

# Database
# SQLite (development)
DATABASE_URL=sqlite:///./fitconnect.db

# PostgreSQL (production)
# DATABASE_URL=postgresql://user:password@localhost:5432/fitconnect

# JWT Security
SECRET_KEY=your-super-secret-key-CHANGE-THIS-IN-PRODUCTION-min-32-characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Server
PORT=8080
HOST=0.0.0.0

# Frontend URL (per CORS)
FRONTEND_URL=http://localhost:3000

# Email (opzionale, per notifiche future)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password

# Admin Default (creato al primo avvio)
ADMIN_EMAIL=admin@fitconnect.com
ADMIN_PASSWORD=admin123
ADMIN_NAME=Admin FitConnect
