{
  "api_version": "1.0.0",
  "base_url": "http://localhost:8080",
  "note": "Questo file contiene 3 esempi per i 3 endpoint MVP - FitConnect",
  
  "mvp_endpoints": {
    
    "1_trainer_registration": {
      "description": "Registrazione di un nuovo personal trainer",
      "endpoint": "POST /api/trainers/register",
      "request": {
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "user_id": 1,
          "bio": "Specializzato in powerlifting con 10 anni di esperienza",
          "hourly_rate": 50.0,
          "location": "Milano",
          "specialization_ids": [1, 2]
        }
      },
      "response": {
        "status_code": 201,
        "body": {
          "id": 1,
          "user_id": 1,
          "user": {
            "id": 1,
            "email": "marco.rossi@example.com",
            "name": "Marco Rossi",
            "role": "trainer",
            "created_at": "2026-01-15T10:30:00"
          },
          "bio": "Specializzato in powerlifting con 10 anni di esperienza",
          "hourly_rate": 50.0,
          "location": "Milano",
          "specializations": [
            {
              "id": 1,
              "name": "Powerlifting"
            },
            {
              "id": 2,
              "name": "CrossFit"
            }
          ],
          "created_at": "2026-03-01T10:00:00"
        }
      },
      "validations": [
        "user_id deve esistere nel sistema",
        "hourly_rate deve essere > 0",
        "specialization_ids devono riferirsi a specializzazioni esistenti",
        "Lo stesso utente non può essere registrato come trainer due volte"
      ]
    },

    "2_trainer_search": {
      "description": "Ricerca trainer con filtri opzionali (location, specializzazione, tariffa massima)",
      "endpoint": "GET /api/trainers/search",
      "query_parameters": {
        "location": "optional string - case-insensitive partial match",
        "specialization": "optional string - exact match nome",
        "max_rate": "optional float - filtra by hourly_rate <= value"
      },
      "example_urls": [
        "GET /api/trainers/search",
        "GET /api/trainers/search?location=Milano",
        "GET /api/trainers/search?max_rate=45.0",
        "GET /api/trainers/search?specialization=Yoga",
        "GET /api/trainers/search?location=Roma&max_rate=50.0&specialization=Pilates"
      ],
      "response": {
        "status_code": 200,
        "body": [
          {
            "id": 1,
            "name": "Marco Rossi",
            "location": "Milano",
            "hourly_rate": 50.0,
            "bio": "Specializzato in powerlifting con 10 anni di esperienza",
            "specializations": ["Powerlifting", "CrossFit"]
          },
          {
            "id": 2,
            "name": "Anna Bianchi",
            "location": "Roma",
            "hourly_rate": 40.0,
            "bio": "Istruttrice di yoga e pilates, diplomata IYENGAR",
            "specializations": ["Yoga", "Pilates"]
          }
        ]
      },
      "validations": [
        "Tutti i parametri sono opzionali",
        "Se nessun filtro: restituisce tutti i trainer",
        "I filtri si combinano con logica AND"
      ]
    },

    "3_session_booking": {
      "description": "Prenotazione di una sessione di allenamento con un trainer",
      "endpoint": "POST /api/sessions",
      "request": {
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "date": "2026-03-15",
          "time": "10:00",
          "status": "scheduled",
          "trainer_id": 1,
          "user_id": 3
        }
      },
      "response": {
        "status_code": 201,
        "body": {
          "id": 101,
          "date": "2026-03-15",
          "time": "10:00",
          "status": "scheduled",
          "trainer_id": 1,
          "user_id": 3,
          "created_at": "2026-03-01T11:00:00",
          "trainer": {
            "id": 1,
            "user_id": 1,
            "user": {
              "id": 1,
              "email": "marco.rossi@example.com",
              "name": "Marco Rossi",
              "role": "trainer",
              "created_at": "2026-01-15T10:30:00"
            },
            "bio": "Specializzato in powerlifting con 10 anni di esperienza",
            "hourly_rate": 50.0,
            "location": "Milano",
            "specializations": [
              {
                "id": 1,
                "name": "Powerlifting"
              },
              {
                "id": 2,
                "name": "CrossFit"
              }
            ],
            "created_at": "2026-01-15T10:30:00"
          },
          "user": {
            "id": 3,
            "email": "luca.verdi@example.com",
            "name": "Luca Verdi",
            "role": "client",
            "created_at": "2026-02-01T09:15:00"
          }
        }
      },
      "validations": [
        "date formato YYYY-MM-DD (data valida nel futuro)",
        "time formato HH:MM (ora valida 00:00-23:59)",
        "trainer_id deve esistere e essere un trainer registrato",
        "user_id deve esistere",
        "Nessun conflitto: impossibile prenotare lo stesso slot (date + time + trainer_id) due volte",
        "status deve essere uno tra: scheduled, completed, cancelled"
      ]
    }
  },

  "error_examples": {
    
    "duplicate_email": {
      "description": "Tentativo di registrare utente con email già esistente",
      "endpoint": "POST /api/users/register",
      "status_code": 400,
      "response": {
        "detail": "Email already registered"
      }
    },

    "trainer_not_found": {
      "description": "Tentativo di prenotare sessione con trainer non esistente",
      "endpoint": "POST /api/sessions",
      "status_code": 404,
      "response": {
        "detail": "Trainer not found"
      }
    },

    "duplicate_time_slot": {
      "description": "Tentativo di prenotare slot orario già occupato per lo stesso trainer",
      "endpoint": "POST /api/sessions",
      "request_body": {
        "date": "2026-03-15",
        "time": "10:00",
        "trainer_id": 1,
        "user_id": 3
      },
      "status_code": 400,
      "response": {
        "detail": "This time slot is already booked"
      }
    },

    "invalid_date_format": {
      "description": "Tentativo di prenotare sessione con formato data non valido",
      "endpoint": "POST /api/sessions",
      "request_body": {
        "date": "15/03/2026",
        "time": "10:00",
        "trainer_id": 1,
        "user_id": 3
      },
      "status_code": 400,
      "response": {
        "detail": "Invalid date format (YYYY-MM-DD)"
      }
    },

    "invalid_time_format": {
      "description": "Tentativo di prenotare sessione con formato ora non valido",
      "endpoint": "POST /api/sessions",
      "request_body": {
        "date": "2026-03-15",
        "time": "10.00",
        "trainer_id": 1,
        "user_id": 3
      },
      "status_code": 400,
      "response": {
        "detail": "Invalid time format (HH:MM)"
      }
    }
  },

